#!/usr/bin/env bash
set -euo pipefail

# =============================================================================
# Claude Code Orchestrator — CLI
# Manages long-running Claude Code worker sessions via tmux.
# =============================================================================

ORCH_HOME="${ORCH_HOME:-$HOME/.claude-orchestrator}"
CONFIG="$ORCH_HOME/config.json"
WORKERS_DIR="$ORCH_HOME/workers"
TEMPLATES_DIR="$ORCH_HOME/templates"
HOOKS_DIR="$ORCH_HOME/hooks"
TMUX_PREFIX="orch-"

# =============================================================================
# Helpers
# =============================================================================

die() {
  echo "error: $*" >&2
  exit 1
}

require_tmux() {
  command -v tmux &>/dev/null || die "tmux is required. Install with: brew install tmux"
}

require_claude() {
  command -v claude &>/dev/null || die "claude CLI is required. See: https://claude.ai/download"
}

require_worker() {
  local name="$1"
  [ -d "$WORKERS_DIR/$name" ] || die "Worker '$name' not found."
}

tmux_session_exists() {
  tmux has-session -t "$1" 2>/dev/null
}

read_config() {
  local key="$1"
  local default="${2:-}"
  if command -v jq &>/dev/null && [ -f "$CONFIG" ]; then
    local val
    val=$(jq -r ".$key // empty" "$CONFIG" 2>/dev/null)
    if [ -n "$val" ]; then
      echo "$val"
      return
    fi
  fi
  echo "$default"
}

worker_count() {
  local count=0
  if [ -d "$WORKERS_DIR" ]; then
    for d in "$WORKERS_DIR"/*/; do
      [ -d "$d" ] && count=$((count + 1))
    done
  fi
  echo "$count"
}

read_worker_field() {
  local name="$1" field="$2"
  if command -v jq &>/dev/null && [ -f "$WORKERS_DIR/$name/meta.json" ]; then
    jq -r ".$field // empty" "$WORKERS_DIR/$name/meta.json" 2>/dev/null
  fi
}

human_duration() {
  local seconds="$1"
  if [ "$seconds" -lt 60 ]; then
    echo "${seconds}s"
  elif [ "$seconds" -lt 3600 ]; then
    echo "$((seconds / 60))m"
  elif [ "$seconds" -lt 86400 ]; then
    echo "$((seconds / 3600))h $((seconds % 3600 / 60))m"
  else
    echo "$((seconds / 86400))d $((seconds % 86400 / 3600))h"
  fi
}

# Template rendering: substitute {{VAR}} placeholders and handle {{#if VAR}}...{{/if}} blocks.
# Usage: render_template <template_file> KEY1=val1 KEY2=val2 ...
# Compatible with bash 3.2 (no associative arrays).
render_template() {
  local template_file="$1"
  shift

  local content
  content=$(<"$template_file")

  # Strip YAML frontmatter if present (--- delimited block at start of file)
  if printf '%s\n' "$content" | head -1 | grep -q "^---$"; then
    content=$(printf '%s\n' "$content" | awk 'BEGIN{skip=0; first=1} {if(first && $0=="---"){skip=1; first=0; next} if(skip && $0=="---"){skip=0; next} if(!skip) print}')
  fi

  # First pass: handle {{#if VAR}}...{{/if}} conditional blocks.
  # For each KEY=val pair, if val is empty, remove the block; if non-empty, keep content.
  for pair in "$@"; do
    local key="${pair%%=*}"
    local val="${pair#*=}"
    if [ -z "$val" ]; then
      # Remove the entire block between {{#if KEY}} and the next {{/if}}
      content=$(printf '%s\n' "$content" | awk -v opentag="{{#if $key}}" -v closetag="{{/if}}" '
        BEGIN { skip = 0 }
        {
          if (index($0, opentag)) { skip = 1; next }
          if (skip && index($0, closetag)) { skip = 0; next }
          if (!skip) print
        }
      ')
    else
      # Keep content, remove the marker lines containing this specific {{#if KEY}}
      content=$(printf '%s\n' "$content" | grep -v "{{#if $key}}")
    fi
  done

  # Remove any remaining {{/if}} markers
  content=$(printf '%s\n' "$content" | sed 's/{{\/if}}//g')

  # Second pass: placeholder substitution using awk (handles multi-line values safely)
  for pair in "$@"; do
    local key="${pair%%=*}"
    local val="${pair#*=}"
    # Write value to temp file so awk can read it (avoids shell escaping issues)
    local val_file
    val_file=$(mktemp)
    printf '%s' "$val" > "$val_file"
    content=$(printf '%s\n' "$content" | awk -v placeholder="{{${key}}}" -v valfile="$val_file" '
      BEGIN {
        val = ""
        while ((getline line < valfile) > 0) {
          if (val != "") val = val "\n"
          val = val line
        }
        close(valfile)
      }
      {
        idx = index($0, placeholder)
        if (idx > 0) {
          before = substr($0, 1, idx - 1)
          after = substr($0, idx + length(placeholder))
          print before val after
        } else {
          print
        }
      }
    ')
    rm -f "$val_file"
  done

  printf '%s\n' "$content"
}

# =============================================================================
# Subcommands
# =============================================================================

cmd_help() {
  cat <<'EOF'
Usage: orch <command> [args]

Worker commands:
  spawn <name> <dir> <prompt> [options]   Spawn a new worker
    --ssh <user@host>                     SSH target for the worker
    --project <name>                      Attach to a project
    --template <name>                     System prompt template (default: "default")
    --model <model>                       Model override
    --after <worker>                      Wait for worker to finish before starting
    --no-permissions-skip                 Require permission approvals

  send <name> <message>                   Send a directive to a worker
  status [name]                           Show worker status (all or one)
  list                                    List all workers
  logs <name> [--tail N]                  Show worker terminal output
  kill <name>                             Gracefully stop a worker
  attach <name>                           Attach to a worker's tmux session
  remodel <name> <model>                 Switch a worker to a different model
  cleanup                                 Remove finished workers older than 24h
  start                                   Start the orchestrator (tmux + Discord)
  stop                                    Stop the orchestrator
  setup                                   Guided setup wizard (Discord, tokens, etc.)
  help                                    Show this help message

Project commands:
  project create <name> <context>         Create a project
  project update <name> <context>         Update project context
  project link <name> <chan_id> <msg_id>  Link project to Discord channel
  project archive <name>                  Archive a project
  project list                            List all projects

Memory commands:
  memory list [--user] [--project <n>]    List memory entries
  memory show <layer>:<id>                Show a memory file
  memory rebuild [--all] [--project <n>]  Rebuild memory indexes
  memory promote <worker> <id> --to <dst> Promote worker memory
  memory add <layer> <id> <title> [opts]  Create a memory entry
  memory consolidate --user|--project <n> Merge/dedup memories
EOF
}

cmd_spawn() {
  require_tmux
  require_claude

  # Parse arguments
  local name="" dir="" prompt=""
  local ssh_host="" project="" template="default" model="" no_perms_skip=false after=""
  local positional=()

  while [ $# -gt 0 ]; do
    case "$1" in
      --ssh)        ssh_host="$2"; shift 2 ;;
      --project)    project="$2"; shift 2 ;;
      --template)   template="$2"; shift 2 ;;
      --model)      model="$2"; shift 2 ;;
      --after)      after="$2"; shift 2 ;;
      --no-permissions-skip) no_perms_skip=true; shift ;;
      -*)           die "Unknown option: $1" ;;
      *)            positional+=("$1"); shift ;;
    esac
  done

  [ ${#positional[@]} -ge 3 ] || die "Usage: orch spawn <name> <dir> <prompt> [options]"

  name="${positional[0]}"
  dir="${positional[1]}"
  prompt="${positional[2]}"

  # Validate name
  [[ "$name" =~ ^[a-zA-Z0-9_-]+$ ]] || die "Invalid worker name '$name'. Use only letters, numbers, hyphens, underscores."

  # Check not already exists
  [ ! -d "$WORKERS_DIR/$name" ] || die "Worker '$name' already exists. Kill it first or choose a different name."

  # Resolve and validate directory
  dir=$(cd "$dir" 2>/dev/null && pwd) || die "Directory '$dir' does not exist."

  # Check max workers
  local max_workers
  max_workers=$(read_config "max_workers" "12")
  local current
  current=$(worker_count)
  [ "$current" -lt "$max_workers" ] || die "Maximum workers ($max_workers) reached. Kill a worker first."

  # Check template exists
  local template_file="$TEMPLATES_DIR/${template}.md"
  [ -f "$template_file" ] || die "Template '$template' not found at $template_file"

  # Read template frontmatter for default_model (if not overridden by --model)
  if [ -z "$model" ]; then
    # Check for YAML frontmatter: --- on first line, default_model field
    local template_model=""
    if head -1 "$template_file" | grep -q "^---$"; then
      template_model=$(sed -n '2,/^---$/p' "$template_file" | grep "^default_model:" | head -1 | sed 's/^default_model: *//')
    fi
    if [ -n "$template_model" ]; then
      model="$template_model"
    else
      model=$(read_config "default_model" "sonnet")
    fi
  fi

  local perms_skip
  perms_skip=$(read_config "permissions_skip" "true")
  if [ "$no_perms_skip" = true ]; then
    perms_skip="false"
  fi
  local channel_port
  channel_port=$(read_config "channel_port" "9111")

  # Create worker directory
  local worker_dir="$WORKERS_DIR/$name"
  mkdir -p "$worker_dir/inbox" "$worker_dir/outbox"

  # Read project context if applicable
  local project_context=""
  if [ -n "$project" ] && [ -f "$ORCH_HOME/projects/${project}.json" ]; then
    if command -v jq &>/dev/null; then
      project_context=$(jq -r '.context // empty' "$ORCH_HOME/projects/${project}.json" 2>/dev/null)
    fi
  fi

  # Write meta.json
  local created
  created=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  cat > "$worker_dir/meta.json" <<METAEOF
{
  "name": "$name",
  "project": $([ -n "$project" ] && echo "\"$project\"" || echo "null"),
  "created": "$created",
  "dir": "$dir",
  "prompt": $(printf '%s' "$prompt" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))'),
  "ssh_host": $([ -n "$ssh_host" ] && echo "\"$ssh_host\"" || echo "null"),
  "tmux_session": "${TMUX_PREFIX}${name}",
  "model": "$model",
  "template": "$template",
  "depends_on": $([ -n "$after" ] && echo "\"$after\"" || echo "null")
}
METAEOF

  # If --after is specified, defer launch
  if [ -n "$after" ]; then
    echo "waiting" > "$worker_dir/status"
    echo "$prompt" > "$worker_dir/task"
    date +%s > "$worker_dir/heartbeat"
    echo "Worker '$name' created with dependency on '$after'."
    echo "  Will auto-launch when '$after' completes (status → done)."
    echo "  The monitor checks every 60 seconds."
    return
  fi

  # Write status and task
  echo "starting" > "$worker_dir/status"
  echo "$prompt" > "$worker_dir/task"
  date +%s > "$worker_dir/heartbeat"

  # Snapshot project context
  if [ -n "$project_context" ]; then
    echo "$project_context" > "$worker_dir/project-context.md"
  fi

  # Create worker memory directory
  mkdir -p "$worker_dir/memory"

  # Read memory indexes for injection
  local user_memory_index="" project_memory_index="" patterns_memory_index="" memory_context=""

  # Rebuild indexes to ensure freshness
  [ -d "$MEMORY_DIR/user" ] && rebuild_memory_index "$MEMORY_DIR/user" "User Memory"
  [ -d "$MEMORY_DIR/patterns" ] && rebuild_memory_index "$MEMORY_DIR/patterns" "Patterns"
  if [ -n "$project" ] && [ -d "$ORCH_HOME/projects/$project/memory" ]; then
    rebuild_memory_index "$ORCH_HOME/projects/$project/memory" "Project: $project"
  fi

  # Read indexes
  if [ -f "$MEMORY_DIR/user/_index.md" ]; then
    user_memory_index=$(<"$MEMORY_DIR/user/_index.md")
    memory_context="1"
  fi
  if [ -f "$MEMORY_DIR/patterns/_index.md" ]; then
    patterns_memory_index=$(<"$MEMORY_DIR/patterns/_index.md")
    memory_context="1"
  fi
  if [ -n "$project" ] && [ -f "$ORCH_HOME/projects/$project/memory/_index.md" ]; then
    project_memory_index=$(<"$ORCH_HOME/projects/$project/memory/_index.md")
    memory_context="1"
  fi

  # Render system prompt
  render_template "$template_file" \
    "WORKER_NAME=$name" \
    "WORKER_DIR=$dir" \
    "SSH_HOST=$ssh_host" \
    "PROJECT_NAME=$project" \
    "PROJECT_CONTEXT=$project_context" \
    "ORCH_HOME=$ORCH_HOME" \
    "CHANNEL_PORT=$channel_port" \
    "MEMORY_CONTEXT=$memory_context" \
    "USER_MEMORY_INDEX=$user_memory_index" \
    "PROJECT_MEMORY_INDEX=$project_memory_index" \
    "PATTERNS_MEMORY_INDEX=$patterns_memory_index" \
    > "$worker_dir/system-prompt.md"

  # Append project-specific worker template from memory (if exists)
  if [ -n "$project" ]; then
    local project_template="$ORCH_HOME/projects/$project/memory/worker-template.md"
    if [ -f "$project_template" ]; then
      # Strip frontmatter and append
      local custom_instructions
      if head -1 "$project_template" | grep -q "^---$"; then
        custom_instructions=$(awk 'BEGIN{skip=0;first=1} {if(first && $0=="---"){skip=1;first=0;next} if(skip && $0=="---"){skip=0;next} if(!skip) print}' "$project_template")
      else
        custom_instructions=$(<"$project_template")
      fi
      printf '\n## Project-Specific Instructions\n%s\n' "$custom_instructions" >> "$worker_dir/system-prompt.md"
    fi
  fi

  # Generate worker settings.json with hook
  cat > "$worker_dir/settings.json" <<SETEOF
{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOOKS_DIR/notify-main.sh"
          }
        ]
      }
    ]
  }
}
SETEOF

  # Create tmux session
  local tmux_name="${TMUX_PREFIX}${name}"
  tmux new-session -d -s "$tmux_name" -c "$dir"

  # Set environment variables
  tmux send-keys -t "$tmux_name" "export ORCH_WORKER_NAME='$name' ORCH_HOME='$ORCH_HOME'" Enter

  # Build claude command
  local claude_cmd="claude"
  claude_cmd+=" --name '${name}'"
  claude_cmd+=" --system-prompt-file '${worker_dir}/system-prompt.md'"
  claude_cmd+=" --settings '${worker_dir}/settings.json'"
  claude_cmd+=" --model '${model}'"
  claude_cmd+=" --add-dir '${ORCH_HOME}/workers/${name}'"
  if [ "$perms_skip" = "true" ]; then
    claude_cmd+=" --dangerously-skip-permissions"
  fi

  # Launch claude
  tmux send-keys -t "$tmux_name" "$claude_cmd" Enter

  # If using --dangerously-skip-permissions, accept the confirmation prompt.
  # The prompt shows two options: 1=No (default), 2=Yes.
  # Wait for the prompt to appear, then navigate down and confirm.
  if [ "$perms_skip" = "true" ]; then
    sleep 4
    tmux send-keys -t "$tmux_name" Down
    sleep 0.5
    tmux send-keys -t "$tmux_name" Enter
  fi

  # Wait for claude to fully start
  sleep 4

  # Use load-buffer + paste-buffer to handle special characters in prompts
  printf '%s' "$prompt" | tmux load-buffer -b "orch-prompt-${name}" -
  tmux paste-buffer -b "orch-prompt-${name}" -t "$tmux_name"
  tmux send-keys -t "$tmux_name" Enter
  tmux delete-buffer -b "orch-prompt-${name}" 2>/dev/null || true

  # Update status
  echo "running" > "$worker_dir/status"

  echo "Worker '$name' spawned in tmux session '$tmux_name'"
  echo "  Directory: $dir"
  echo "  Model: $model"
  [ -n "$ssh_host" ] && echo "  SSH: $ssh_host"
  [ -n "$project" ] && echo "  Project: $project"
  echo "  Use 'orch status $name' to check progress"
  echo "  Use 'orch logs $name' to see terminal output"
}

cmd_send() {
  [ $# -ge 2 ] || die "Usage: orch send <name> <message>"
  local name="$1"
  shift
  local message="$*"

  require_worker "$name"

  local inbox_dir="$WORKERS_DIR/$name/inbox"
  mkdir -p "$inbox_dir"

  # Find next inbox number
  local max_num=0
  shopt -s nullglob
  for f in "$inbox_dir"/*.md; do
    local base
    base=$(basename "$f" .md)
    local num=$((10#$base))
    [ "$num" -gt "$max_num" ] && max_num=$num
  done
  shopt -u nullglob
  local next_num
  next_num=$(printf "%03d" $((max_num + 1)))

  # Write directive
  local timestamp
  timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  cat > "$inbox_dir/${next_num}.md" <<EOF
# Directive ${next_num}
Received: ${timestamp}

${message}
EOF

  echo "Directive sent to '$name' (inbox/${next_num}.md)"

  # Nudge the worker if tmux session is alive
  local tmux_name="${TMUX_PREFIX}${name}"
  if tmux_session_exists "$tmux_name"; then
    tmux send-keys -t "$tmux_name" \
      "Check your inbox at $ORCH_HOME/workers/$name/inbox/ for new directives." Enter
  else
    echo "warning: tmux session '$tmux_name' not found. Directive written to inbox but worker may be dead." >&2
  fi
}

cmd_status() {
  if [ $# -eq 0 ]; then
    cmd_list
    return
  fi

  local name="$1"
  require_worker "$name"

  local worker_dir="$WORKERS_DIR/$name"
  local tmux_name="${TMUX_PREFIX}${name}"

  # Read metadata
  echo "=== Worker: $name ==="
  echo ""

  if [ -f "$worker_dir/meta.json" ] && command -v jq &>/dev/null; then
    echo "Created:   $(jq -r '.created // "unknown"' "$worker_dir/meta.json")"
    echo "Directory: $(jq -r '.dir // "unknown"' "$worker_dir/meta.json")"
    echo "Model:     $(jq -r '.model // "unknown"' "$worker_dir/meta.json")"
    local ssh
    ssh=$(jq -r '.ssh_host // empty' "$worker_dir/meta.json")
    [ -n "$ssh" ] && echo "SSH:       $ssh"
    local proj
    proj=$(jq -r '.project // empty' "$worker_dir/meta.json")
    [ -n "$proj" ] && echo "Project:   $proj"
  fi

  # Status
  local status="unknown"
  [ -f "$worker_dir/status" ] && status=$(<"$worker_dir/status")
  echo "Status:    $status"

  # Uptime
  if [ -f "$worker_dir/meta.json" ] && command -v jq &>/dev/null; then
    local created_str
    created_str=$(jq -r '.created // empty' "$worker_dir/meta.json")
    if [ -n "$created_str" ]; then
      local created_epoch
      created_epoch=$(TZ=UTC date -j -f "%Y-%m-%dT%H:%M:%SZ" "$created_str" +%s 2>/dev/null || echo "")
      if [ -n "$created_epoch" ]; then
        local now
        now=$(date +%s)
        echo "Uptime:    $(human_duration $((now - created_epoch)))"
      fi
    fi
  fi

  # Heartbeat
  if [ -f "$worker_dir/heartbeat" ]; then
    local hb
    hb=$(<"$worker_dir/heartbeat")
    local now
    now=$(date +%s)
    local age=$((now - hb))
    echo "Heartbeat: $(human_duration $age) ago"
    if [ "$age" -gt 300 ] && [ "$status" = "running" ]; then
      echo "           ⚠ Heartbeat stale (>5min). Worker may be stuck."
    fi
  fi

  # Task
  echo ""
  if [ -f "$worker_dir/task" ]; then
    echo "Task:"
    sed 's/^/  /' "$worker_dir/task"
  fi

  # Inbox/Outbox counts
  local inbox_count=0 outbox_count=0
  [ -d "$worker_dir/inbox" ] && inbox_count=$(find "$worker_dir/inbox" -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')
  [ -d "$worker_dir/outbox" ] && outbox_count=$(find "$worker_dir/outbox" -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')
  echo ""
  echo "Inbox:     $inbox_count pending directive(s)"
  echo "Outbox:    $outbox_count update(s)"

  # Tool usage
  local tool_count=0
  [ -f "$worker_dir/tool_count" ] && tool_count=$(<"$worker_dir/tool_count")
  echo "Tools:     $tool_count calls"

  # tmux status
  echo ""
  if tmux_session_exists "$tmux_name"; then
    echo "tmux:      alive ($tmux_name)"
    echo ""
    echo "--- Last 20 lines of terminal ---"
    tmux capture-pane -t "$tmux_name" -p -S -20 2>/dev/null || echo "(could not capture)"
  else
    echo "tmux:      dead ($tmux_name not found)"
  fi
}

cmd_list() {
  if [ ! -d "$WORKERS_DIR" ] || [ -z "$(ls -A "$WORKERS_DIR" 2>/dev/null)" ]; then
    echo "No workers found."
    return
  fi

  # Print header
  printf "%-20s %-10s %-10s %-12s %-15s %s\n" "NAME" "STATUS" "MODEL" "UPTIME" "HEARTBEAT" "TMUX"
  printf "%-20s %-10s %-10s %-12s %-15s %s\n" "----" "------" "-----" "------" "---------" "----"

  local now
  now=$(date +%s)

  for worker_dir in "$WORKERS_DIR"/*/; do
    [ -d "$worker_dir" ] || continue
    local name
    name=$(basename "$worker_dir")

    # Status
    local status="?"
    [ -f "$worker_dir/status" ] && status=$(<"$worker_dir/status")

    # Model
    local model="?"
    if command -v jq &>/dev/null && [ -f "$worker_dir/meta.json" ]; then
      model=$(jq -r '.model // "?"' "$worker_dir/meta.json")
    fi

    # Uptime
    local uptime="?"
    if command -v jq &>/dev/null && [ -f "$worker_dir/meta.json" ]; then
      local created_str
      created_str=$(jq -r '.created // empty' "$worker_dir/meta.json")
      if [ -n "$created_str" ]; then
        local created_epoch
        created_epoch=$(TZ=UTC date -j -f "%Y-%m-%dT%H:%M:%SZ" "$created_str" +%s 2>/dev/null || echo "")
        if [ -n "$created_epoch" ]; then
          uptime=$(human_duration $((now - created_epoch)))
        fi
      fi
    fi

    # Heartbeat
    local heartbeat="?"
    if [ -f "$worker_dir/heartbeat" ]; then
      local hb
      hb=$(<"$worker_dir/heartbeat")
      heartbeat="$(human_duration $((now - hb))) ago"
    fi

    # tmux
    local tmux_name="${TMUX_PREFIX}${name}"
    local tmux_status="dead"
    tmux_session_exists "$tmux_name" && tmux_status="alive"

    printf "%-20s %-10s %-10s %-12s %-15s %s\n" "$name" "$status" "$model" "$uptime" "$heartbeat" "$tmux_status"
  done
}

cmd_logs() {
  [ $# -ge 1 ] || die "Usage: orch logs <name> [--tail N]"
  local name="$1"
  shift

  require_worker "$name"
  require_tmux

  local tail_n=50
  while [ $# -gt 0 ]; do
    case "$1" in
      --tail) tail_n="$2"; shift 2 ;;
      *)      die "Unknown option: $1" ;;
    esac
  done

  local tmux_name="${TMUX_PREFIX}${name}"
  tmux_session_exists "$tmux_name" || die "tmux session '$tmux_name' not found. Worker may have exited."

  tmux capture-pane -t "$tmux_name" -p -S "-${tail_n}"
}

cmd_kill() {
  [ $# -ge 1 ] || die "Usage: orch kill <name> [--rm]"
  local name="$1"
  local remove=false
  [ "${2:-}" = "--rm" ] && remove=true

  require_worker "$name"

  local worker_dir="$WORKERS_DIR/$name"
  local tmux_name="${TMUX_PREFIX}${name}"

  if tmux_session_exists "$tmux_name"; then
    # Try graceful exit first
    tmux send-keys -t "$tmux_name" "/exit" Enter

    # Wait up to 5 seconds
    local waited=0
    while [ $waited -lt 5 ]; do
      sleep 1
      waited=$((waited + 1))
      tmux_session_exists "$tmux_name" || break
    done

    # Force kill if still alive
    if tmux_session_exists "$tmux_name"; then
      tmux kill-session -t "$tmux_name" 2>/dev/null || true
      echo "Worker '$name' force-killed (did not exit gracefully)."
    else
      echo "Worker '$name' exited gracefully."
    fi
  else
    echo "Worker '$name' tmux session already gone."
  fi

  # Auto-promote worker memories to project before cleanup
  if [ -d "$worker_dir/memory" ] && command -v jq &>/dev/null; then
    local project_name
    project_name=$(jq -r '.project // empty' "$worker_dir/meta.json" 2>/dev/null)
    if [ -n "$project_name" ]; then
      local project_mem_dir="$ORCH_HOME/projects/$project_name/memory"
      mkdir -p "$project_mem_dir"
      shopt -s nullglob
      local promoted=0
      for mem_file in "$worker_dir/memory"/*.md; do
        local mem_base
        mem_base=$(basename "$mem_file")
        [ "$mem_base" = "_index.md" ] && continue
        cp "$mem_file" "$project_mem_dir/$mem_base"
        promoted=$((promoted + 1))
      done
      shopt -u nullglob
      if [ "$promoted" -gt 0 ]; then
        rebuild_memory_index "$project_mem_dir" "Project: $project_name"
        echo "Promoted $promoted memory file(s) to project '$project_name'."
      fi
    fi
  fi

  if [ "$remove" = true ]; then
    rm -rf "$worker_dir"
    echo "Worker '$name' removed."
  else
    echo "killed" > "$worker_dir/status"
  fi
}

cmd_cleanup() {
  if [ ! -d "$WORKERS_DIR" ] || [ -z "$(ls -A "$WORKERS_DIR" 2>/dev/null)" ]; then
    echo "Nothing to clean up."
    return
  fi

  local now
  now=$(date +%s)
  local cleaned=0

  for worker_dir in "$WORKERS_DIR"/*/; do
    [ -d "$worker_dir" ] || continue
    local name
    name=$(basename "$worker_dir")

    # Only clean up finished workers
    local status=""
    [ -f "$worker_dir/status" ] && status=$(<"$worker_dir/status")
    case "$status" in
      done|killed|error) ;;
      *) continue ;;
    esac

    # Check age
    if command -v jq &>/dev/null && [ -f "$worker_dir/meta.json" ]; then
      local created_str
      created_str=$(jq -r '.created // empty' "$worker_dir/meta.json")
      if [ -n "$created_str" ]; then
        local created_epoch
        created_epoch=$(TZ=UTC date -j -f "%Y-%m-%dT%H:%M:%SZ" "$created_str" +%s 2>/dev/null || echo "")
        if [ -n "$created_epoch" ]; then
          local age=$((now - created_epoch))
          if [ "$age" -gt 86400 ]; then
            rm -rf "$worker_dir"
            echo "Cleaned up: $name (${status}, $(human_duration $age) old)"
            cleaned=$((cleaned + 1))
          fi
        fi
      fi
    fi
  done

  if [ "$cleaned" -eq 0 ]; then
    echo "Nothing to clean up. (Finished workers must be >24h old.)"
  else
    echo "Cleaned up $cleaned worker(s)."
  fi
}

# =============================================================================
# Project subcommands
# =============================================================================

PROJECTS_DIR="$ORCH_HOME/projects"

cmd_project() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    create)  cmd_project_create "$@" ;;
    update)  cmd_project_update "$@" ;;
    link)    cmd_project_link "$@" ;;
    archive) cmd_project_archive "$@" ;;
    list)    cmd_project_list "$@" ;;
    *)       die "Usage: orch project <create|update|link|archive|list> [args]" ;;
  esac
}

cmd_project_create() {
  [ $# -ge 2 ] || die "Usage: orch project create <name> <context>"
  local name="$1"
  shift
  local context="$*"

  [[ "$name" =~ ^[a-zA-Z0-9_-]+$ ]] || die "Invalid project name '$name'. Use only letters, numbers, hyphens, underscores."

  mkdir -p "$PROJECTS_DIR"
  local project_file="$PROJECTS_DIR/${name}.json"
  [ ! -f "$project_file" ] || die "Project '$name' already exists."

  local created
  created=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

  cat > "$project_file" <<PROJEOF
{
  "name": "$name",
  "context": $(printf '%s' "$context" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))'),
  "created": "$created",
  "status": "active",
  "channel_id": null,
  "context_message_id": null
}
PROJEOF

  echo "Project '$name' created."
  echo "  Context: $context"
  echo ""
  echo "To create a Discord channel, ask Claude to call create_project_channel."
  echo "Then link with: orch project link $name <channel_id> <context_msg_id>"
}

cmd_project_update() {
  [ $# -ge 2 ] || die "Usage: orch project update <name> <context>"
  local name="$1"
  shift
  local context="$*"

  local project_file="$PROJECTS_DIR/${name}.json"
  [ -f "$project_file" ] || die "Project '$name' not found."

  if command -v jq &>/dev/null; then
    local tmp
    tmp=$(jq --arg ctx "$context" '.context = $ctx' "$project_file")
    echo "$tmp" > "$project_file"
  else
    die "jq is required for project update"
  fi

  echo "Project '$name' context updated."
}

cmd_project_link() {
  [ $# -ge 3 ] || die "Usage: orch project link <name> <channel_id> <context_message_id>"
  local name="$1"
  local channel_id="$2"
  local context_msg_id="$3"

  local project_file="$PROJECTS_DIR/${name}.json"
  [ -f "$project_file" ] || die "Project '$name' not found."

  if command -v jq &>/dev/null; then
    local tmp
    tmp=$(jq --arg cid "$channel_id" --arg mid "$context_msg_id" \
      '.channel_id = $cid | .context_message_id = $mid' "$project_file")
    echo "$tmp" > "$project_file"
  else
    die "jq is required for project link"
  fi

  echo "Project '$name' linked to Discord channel $channel_id."
}

cmd_project_archive() {
  [ $# -ge 1 ] || die "Usage: orch project archive <name>"
  local name="$1"

  local project_file="$PROJECTS_DIR/${name}.json"
  [ -f "$project_file" ] || die "Project '$name' not found."

  if command -v jq &>/dev/null; then
    local tmp
    tmp=$(jq '.status = "archived"' "$project_file")
    echo "$tmp" > "$project_file"
  else
    die "jq is required for project archive"
  fi

  echo "Project '$name' archived."
}

cmd_project_list() {
  mkdir -p "$PROJECTS_DIR"

  if [ -z "$(ls -A "$PROJECTS_DIR" 2>/dev/null)" ]; then
    echo "No projects found."
    return
  fi

  printf "%-20s %-10s %-22s %s\n" "NAME" "STATUS" "CHANNEL" "WORKERS"
  printf "%-20s %-10s %-22s %s\n" "----" "------" "-------" "-------"

  for project_file in "$PROJECTS_DIR"/*.json; do
    [ -f "$project_file" ] || continue

    if command -v jq &>/dev/null; then
      local name status channel_id
      name=$(jq -r '.name // "?"' "$project_file")
      status=$(jq -r '.status // "?"' "$project_file")
      channel_id=$(jq -r '.channel_id // "not linked"' "$project_file")
      if [ "$channel_id" = "null" ]; then channel_id="not linked"; fi

      # Count workers attached to this project
      local worker_count=0
      if [ -d "$WORKERS_DIR" ]; then
        for wd in "$WORKERS_DIR"/*/meta.json; do
          [ -f "$wd" ] || continue
          local wp
          wp=$(jq -r '.project // empty' "$wd" 2>/dev/null)
          [ "$wp" = "$name" ] && worker_count=$((worker_count + 1))
        done
      fi

      printf "%-20s %-10s %-22s %s\n" "$name" "$status" "$channel_id" "$worker_count"
    fi
  done
}

# =============================================================================
# Memory subcommands
# =============================================================================

MEMORY_DIR="$ORCH_HOME/memory"

# Rebuild _index.md for a memory directory by scanning .md files and parsing frontmatter.
rebuild_memory_index() {
  local mem_dir="$1"
  local label="${2:-Memory}"

  [ -d "$mem_dir" ] || return

  local index_file="$mem_dir/_index.md"
  local entries_file
  entries_file=$(mktemp)

  # Collect entries: category|id|title
  shopt -s nullglob
  for f in "$mem_dir"/*.md; do
    local base
    base=$(basename "$f")
    [ "$base" = "_index.md" ] && continue

    local id="${base%.md}"
    local title="" category="" expires=""

    # Parse YAML frontmatter
    if head -1 "$f" | grep -q "^---$"; then
      title=$(sed -n '2,/^---$/{ /^title:/{ s/^title: *//; p; }; }' "$f" | head -1)
      category=$(sed -n '2,/^---$/{ /^category:/{ s/^category: *//; p; }; }' "$f" | head -1)
      expires=$(sed -n '2,/^---$/{ /^expires:/{ s/^expires: *//; p; }; }' "$f" | head -1)

      # Skip expired
      if [ -n "$expires" ]; then
        local exp_epoch
        exp_epoch=$(TZ=UTC date -j -f "%Y-%m-%dT%H:%M:%SZ" "$expires" +%s 2>/dev/null || echo "")
        if [ -n "$exp_epoch" ] && [ "$(date +%s)" -gt "$exp_epoch" ]; then
          continue
        fi
      fi
    fi

    [ -z "$title" ] && title="$id"
    [ -z "$category" ] && category="reference"

    echo "${category}|${id}|${title}" >> "$entries_file"
  done
  shopt -u nullglob

  # Build index grouped by category
  {
    echo "# ${label}"
    echo ""

    local cat_name cat_label
    for cat_name in environment experiment-result decision preference procedure warning reference; do
      case "$cat_name" in
        environment)       cat_label="Environment" ;;
        experiment-result) cat_label="Experiment Results" ;;
        decision)          cat_label="Decisions" ;;
        preference)        cat_label="Preferences" ;;
        procedure)         cat_label="Procedures" ;;
        warning)           cat_label="Warnings" ;;
        reference)         cat_label="Reference" ;;
      esac

      local has_entries=false
      while IFS='|' read -r ecat eid etitle; do
        if [ "$ecat" = "$cat_name" ]; then
          if [ "$has_entries" = false ]; then
            echo "## ${cat_label}"
            has_entries=true
          fi
          echo "- [${eid}](${eid}.md) — ${etitle}"
        fi
      done < "$entries_file"

      [ "$has_entries" = true ] && echo ""
    done
  } > "$index_file"

  rm -f "$entries_file"
}

cmd_memory() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    list)        cmd_memory_list "$@" ;;
    show)        cmd_memory_show "$@" ;;
    rebuild)     cmd_memory_rebuild "$@" ;;
    promote)     cmd_memory_promote "$@" ;;
    add)         cmd_memory_add "$@" ;;
    consolidate) cmd_memory_consolidate "$@" ;;
    auto-consolidate) cmd_memory_auto_consolidate "$@" ;;
    schedule-consolidation) cmd_memory_schedule_consolidation "$@" ;;
    *)           die "Usage: orch memory <list|show|rebuild|promote|add|consolidate|auto-consolidate|schedule-consolidation> [args]" ;;
  esac
}

cmd_memory_list() {
  local show_user=false show_patterns=false show_project="" show_worker=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --user)     show_user=true; shift ;;
      --patterns) show_patterns=true; shift ;;
      --project)  show_project="$2"; shift 2 ;;
      --worker)   show_worker="$2"; shift 2 ;;
      *)          die "Unknown option: $1" ;;
    esac
  done

  # Default: show all
  if [ "$show_user" = false ] && [ "$show_patterns" = false ] && [ -z "$show_project" ] && [ -z "$show_worker" ]; then
    show_user=true
    show_patterns=true
  fi

  if [ "$show_user" = true ] && [ -f "$MEMORY_DIR/user/_index.md" ]; then
    cat "$MEMORY_DIR/user/_index.md"
    echo ""
  fi

  if [ "$show_patterns" = true ] && [ -f "$MEMORY_DIR/patterns/_index.md" ]; then
    cat "$MEMORY_DIR/patterns/_index.md"
    echo ""
  fi

  if [ -n "$show_project" ]; then
    local idx="$ORCH_HOME/projects/$show_project/memory/_index.md"
    if [ -f "$idx" ]; then
      cat "$idx"
    else
      echo "No memories for project '$show_project'."
    fi
    echo ""
  fi

  if [ -n "$show_worker" ]; then
    local idx="$WORKERS_DIR/$show_worker/memory/_index.md"
    if [ -f "$idx" ]; then
      cat "$idx"
    else
      echo "No memories for worker '$show_worker'."
    fi
    echo ""
  fi

  # If no flags, also list all projects that have memory
  if [ "$show_user" = true ]; then
    shopt -s nullglob
    for pdir in "$ORCH_HOME"/projects/*/memory/_index.md; do
      cat "$pdir"
      echo ""
    done
    shopt -u nullglob
  fi
}

cmd_memory_show() {
  [ $# -ge 1 ] || die "Usage: orch memory show <layer>:<id>  (e.g., user:ssh-config or project:ml-training:optimizer)"
  local spec="$1"

  # Parse layer:id or layer:project:id
  local layer id project_name
  IFS=':' read -r layer project_name id <<< "$spec"

  # If only two parts, it's layer:id (not layer:project:id)
  if [ -z "$id" ]; then
    id="$project_name"
    project_name=""
  fi

  local mem_file=""
  case "$layer" in
    user)     mem_file="$MEMORY_DIR/user/${id}.md" ;;
    patterns) mem_file="$MEMORY_DIR/patterns/${id}.md" ;;
    project)
      [ -n "$project_name" ] || die "Specify project: orch memory show project:<name>:<id>"
      mem_file="$ORCH_HOME/projects/$project_name/memory/${id}.md"
      ;;
    worker)
      [ -n "$project_name" ] || die "Specify worker: orch memory show worker:<name>:<id>"
      mem_file="$WORKERS_DIR/$project_name/memory/${id}.md"
      ;;
    *)  die "Unknown layer '$layer'. Use: user, project, worker, patterns" ;;
  esac

  [ -f "$mem_file" ] || die "Memory not found: $mem_file"
  cat "$mem_file"
}

cmd_memory_rebuild() {
  local rebuild_user=false rebuild_patterns=false rebuild_project="" rebuild_all=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --user)     rebuild_user=true; shift ;;
      --patterns) rebuild_patterns=true; shift ;;
      --project)  rebuild_project="$2"; shift 2 ;;
      --all)      rebuild_all=true; shift ;;
      *)          die "Unknown option: $1" ;;
    esac
  done

  if [ "$rebuild_all" = true ]; then
    rebuild_user=true
    rebuild_patterns=true
  fi

  if [ "$rebuild_user" = true ] || [ "$rebuild_all" = true ]; then
    if [ -d "$MEMORY_DIR/user" ]; then
      rebuild_memory_index "$MEMORY_DIR/user" "User Memory"
      echo "Rebuilt: user memory index"
    fi
  fi

  if [ "$rebuild_patterns" = true ] || [ "$rebuild_all" = true ]; then
    if [ -d "$MEMORY_DIR/patterns" ]; then
      rebuild_memory_index "$MEMORY_DIR/patterns" "Patterns"
      echo "Rebuilt: patterns index"
    fi
  fi

  if [ -n "$rebuild_project" ]; then
    local pdir="$ORCH_HOME/projects/$rebuild_project/memory"
    if [ -d "$pdir" ]; then
      rebuild_memory_index "$pdir" "Project: $rebuild_project"
      echo "Rebuilt: project '$rebuild_project' memory index"
    else
      echo "No memory directory for project '$rebuild_project'."
    fi
  fi

  if [ "$rebuild_all" = true ]; then
    for pdir in "$ORCH_HOME"/projects/*/memory; do
      [ -d "$pdir" ] || continue
      local pname
      pname=$(basename "$(dirname "$pdir")")
      rebuild_memory_index "$pdir" "Project: $pname"
      echo "Rebuilt: project '$pname' memory index"
    done
  fi
}

cmd_memory_promote() {
  [ $# -ge 3 ] || die "Usage: orch memory promote <worker-name> <memory-id> --to <project-name|user>"
  local worker_name="$1"
  local memory_id="$2"
  local target=""

  shift 2
  while [ $# -gt 0 ]; do
    case "$1" in
      --to) target="$2"; shift 2 ;;
      *)    die "Unknown option: $1" ;;
    esac
  done

  [ -n "$target" ] || die "Must specify --to <project-name|user>"

  local src="$WORKERS_DIR/$worker_name/memory/${memory_id}.md"
  [ -f "$src" ] || die "Worker memory not found: $src"

  local dest_dir
  if [ "$target" = "user" ]; then
    dest_dir="$MEMORY_DIR/user"
  else
    dest_dir="$ORCH_HOME/projects/$target/memory"
  fi

  mkdir -p "$dest_dir"
  cp "$src" "$dest_dir/${memory_id}.md"

  # Update source field in promoted file
  if command -v sed &>/dev/null; then
    sed -i '' "s/^source: .*/source: promoted:$worker_name/" "$dest_dir/${memory_id}.md" 2>/dev/null || true
  fi

  rebuild_memory_index "$dest_dir" "$([ "$target" = "user" ] && echo "User Memory" || echo "Project: $target")"
  echo "Promoted '$memory_id' from worker '$worker_name' to $target."
}

cmd_memory_add() {
  local layer="" id="" title="" category="reference" tags=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --category) category="$2"; shift 2 ;;
      --tags)     tags="$2"; shift 2 ;;
      -*)         die "Unknown option: $1" ;;
      *)
        if [ -z "$layer" ]; then layer="$1"
        elif [ -z "$id" ]; then id="$1"
        else title="${title:+$title }$1"
        fi
        shift
        ;;
    esac
  done

  [ -n "$layer" ] && [ -n "$id" ] && [ -n "$title" ] || \
    die "Usage: orch memory add <layer[:project]> <id> <title> --category <cat> [--tags t1,t2]"

  local project_name="" mem_dir=""
  case "$layer" in
    user)     mem_dir="$MEMORY_DIR/user" ;;
    patterns) mem_dir="$MEMORY_DIR/patterns" ;;
    project:*)
      project_name="${layer#project:}"
      mem_dir="$ORCH_HOME/projects/$project_name/memory"
      ;;
    *)  die "Layer must be: user, patterns, or project:<name>" ;;
  esac

  mkdir -p "$mem_dir"

  local created
  created=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

  local tags_line=""
  [ -n "$tags" ] && tags_line="tags: [$(echo "$tags" | sed 's/,/, /g')]"

  cat > "$mem_dir/${id}.md" <<MEMEOF
---
id: $id
title: $title
category: $category
${tags_line:+$tags_line}
created: $created
updated: $created
source: user
confidence: high
---

$title
MEMEOF

  rebuild_memory_index "$mem_dir" "$([ "$layer" = "user" ] && echo "User Memory" || echo "${layer}")"
  echo "Memory '$id' created in $layer."
  echo "  Edit the full content at: $mem_dir/${id}.md"
}

cmd_memory_consolidate() {
  require_claude

  local target_dir="" target_label="" project_name=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --user) target_dir="$MEMORY_DIR/user"; target_label="user memory"; shift ;;
      --project) project_name="$2"; target_dir="$ORCH_HOME/projects/$2/memory"; target_label="project '$2' memory"; shift 2 ;;
      *) die "Usage: orch memory consolidate [--user | --project <name>]" ;;
    esac
  done

  [ -n "$target_dir" ] || die "Specify --user or --project <name>"
  [ -d "$target_dir" ] || die "No memory directory at $target_dir"

  local mem_count=0
  shopt -s nullglob
  for f in "$target_dir"/*.md; do
    [ "$(basename "$f")" = "_index.md" ] && continue
    mem_count=$((mem_count + 1))
  done
  shopt -u nullglob

  if [ "$mem_count" -lt 2 ]; then
    echo "Only $mem_count memory file(s) in $target_label. Nothing to consolidate."
    return
  fi

  echo "Consolidating $mem_count memories in $target_label..."
  echo "Spawning a haiku worker to review and merge..."

  local consolidate_prompt="Read ALL memory files in $target_dir/. There are $mem_count files. For each file, read its content. Then: (1) Identify duplicates or near-duplicates and merge them into single entries. (2) Identify outdated entries and update or remove them. (3) Identify entries that can be combined into a more useful summary. Write consolidated memory files back to the same directory. For merged entries, set supersedes: <old-id> in the frontmatter. Delete the old files after creating the merged version. Rebuild the index when done: run 'orch memory rebuild $([ -n "$project_name" ] && echo "--project $project_name" || echo "--user")'. Post a summary of what you changed."

  local worker_name="consolidate-$(date +%s)"
  orch spawn "$worker_name" "$(pwd)" "$consolidate_prompt" --model haiku

  echo "Consolidation worker '$worker_name' spawned."
  echo "  Check progress: orch logs $worker_name"
}

cmd_memory_auto_consolidate() {
  # Consolidate all projects + user memory that have 3+ entries
  local consolidated=0

  # User memory
  if [ -d "$MEMORY_DIR/user" ]; then
    local count=0
    shopt -s nullglob
    for f in "$MEMORY_DIR/user"/*.md; do
      [ "$(basename "$f")" = "_index.md" ] && continue
      count=$((count + 1))
    done
    shopt -u nullglob
    if [ "$count" -ge 3 ]; then
      echo "User memory: $count entries, consolidating..."
      cmd_memory_consolidate --user
      consolidated=$((consolidated + 1))
    fi
  fi

  # All projects
  shopt -s nullglob
  for proj_dir in "$ORCH_HOME"/projects/*/memory; do
    [ -d "$proj_dir" ] || continue
    local pname
    pname=$(basename "$(dirname "$proj_dir")")
    local count=0
    for f in "$proj_dir"/*.md; do
      [ "$(basename "$f")" = "_index.md" ] && continue
      count=$((count + 1))
    done
    if [ "$count" -ge 3 ]; then
      echo "Project '$pname': $count entries, consolidating..."
      cmd_memory_consolidate --project "$pname"
      consolidated=$((consolidated + 1))
    fi
  done
  shopt -u nullglob

  if [ "$consolidated" -eq 0 ]; then
    echo "No layers have enough memories to consolidate (need 3+)."
  else
    echo "Spawned $consolidated consolidation worker(s)."
  fi
}

cmd_memory_schedule_consolidation() {
  # Install a cron job to run auto-consolidation every 2 days
  local orch_path
  orch_path=$(which orch 2>/dev/null || echo "$HOME/.local/bin/orch")

  local cron_entry="0 3 */2 * * $orch_path memory auto-consolidate >> $ORCH_HOME/consolidation.log 2>&1"

  # Check if already scheduled
  if crontab -l 2>/dev/null | grep -q "orch memory auto-consolidate"; then
    echo "Consolidation is already scheduled:"
    crontab -l 2>/dev/null | grep "orch memory"
    echo ""
    echo "To remove: crontab -e and delete the line."
    return
  fi

  # Add to crontab
  (crontab -l 2>/dev/null; echo "$cron_entry") | crontab -

  echo "Scheduled memory consolidation every 2 days at 3:00 AM."
  echo "  Cron entry: $cron_entry"
  echo "  Log: $ORCH_HOME/consolidation.log"
  echo ""
  echo "To remove: crontab -e and delete the orch line."
}

# =============================================================================
# Attach
# =============================================================================

cmd_spawn_deferred() {
  # Internal command: launches a worker that was deferred with --after
  [ $# -ge 1 ] || die "Usage: orch spawn-deferred <name>"
  local name="$1"

  require_worker "$name"
  require_tmux
  require_claude

  local worker_dir="$WORKERS_DIR/$name"
  local meta_file="$worker_dir/meta.json"

  [ -f "$meta_file" ] || die "No meta.json for worker '$name'"

  if command -v jq &>/dev/null; then
    local dir model prompt tmux_session
    dir=$(jq -r '.dir // empty' "$meta_file")
    model=$(jq -r '.model // "sonnet"' "$meta_file")
    prompt=$(jq -r '.prompt // empty' "$meta_file")
    tmux_session=$(jq -r '.tmux_session // empty' "$meta_file")

    [ -n "$dir" ] || die "No directory in meta.json"
    [ -n "$tmux_session" ] || tmux_session="${TMUX_PREFIX}${name}"

    echo "starting" > "$worker_dir/status"
    date +%s > "$worker_dir/heartbeat"

    local perms_skip
    perms_skip=$(read_config "permissions_skip" "true")

    tmux new-session -d -s "$tmux_session" -c "$dir"
    tmux send-keys -t "$tmux_session" "export ORCH_WORKER_NAME='$name' ORCH_HOME='$ORCH_HOME'" Enter

    local claude_cmd="claude --name '${name}' --system-prompt-file '${worker_dir}/system-prompt.md' --settings '${worker_dir}/settings.json' --model '${model}' --add-dir '${worker_dir}'"
    [ "$perms_skip" = "true" ] && claude_cmd+=" --dangerously-skip-permissions"

    tmux send-keys -t "$tmux_session" "$claude_cmd" Enter

    if [ "$perms_skip" = "true" ]; then
      sleep 4
      tmux send-keys -t "$tmux_session" Down
      sleep 0.5
      tmux send-keys -t "$tmux_session" Enter
    fi

    sleep 4
    printf '%s' "$prompt" | tmux load-buffer -b "orch-prompt-${name}" -
    tmux paste-buffer -b "orch-prompt-${name}" -t "$tmux_session"
    tmux send-keys -t "$tmux_session" Enter
    tmux delete-buffer -b "orch-prompt-${name}" 2>/dev/null || true

    echo "running" > "$worker_dir/status"
    echo "Deferred worker '$name' launched."
  else
    die "jq is required for spawn-deferred"
  fi
}

cmd_remodel() {
  [ $# -ge 2 ] || die "Usage: orch remodel <name> <model>"
  local name="$1"
  local new_model="$2"

  require_worker "$name"
  require_tmux
  require_claude

  local worker_dir="$WORKERS_DIR/$name"
  local meta_file="$worker_dir/meta.json"
  [ -f "$meta_file" ] || die "No meta.json for worker '$name'"

  if ! command -v jq &>/dev/null; then
    die "jq is required for remodel"
  fi

  local old_model dir prompt project template ssh_host
  old_model=$(jq -r '.model // "sonnet"' "$meta_file")
  dir=$(jq -r '.dir // empty' "$meta_file")
  prompt=$(jq -r '.prompt // empty' "$meta_file")
  project=$(jq -r '.project // empty' "$meta_file")
  template=$(jq -r '.template // "default"' "$meta_file")
  ssh_host=$(jq -r '.ssh_host // empty' "$meta_file")

  echo "Switching worker '$name' from $old_model to $new_model..."

  # Kill with --rm (auto-promotes memories to project)
  cmd_kill "$name" --rm

  # Re-spawn with new model
  local spawn_args="$name $dir"
  spawn_args="$spawn_args $prompt"

  local spawn_opts="--model $new_model --template $template"
  [ -n "$project" ] && [ "$project" != "null" ] && spawn_opts="$spawn_opts --project $project"
  [ -n "$ssh_host" ] && [ "$ssh_host" != "null" ] && spawn_opts="$spawn_opts --ssh $ssh_host"

  cmd_spawn "$name" "$dir" "$prompt" --model "$new_model" --template "$template" \
    $([ -n "$project" ] && [ "$project" != "null" ] && echo "--project $project") \
    $([ -n "$ssh_host" ] && [ "$ssh_host" != "null" ] && echo "--ssh $ssh_host")

  echo "Worker '$name' restarted with model $new_model (was $old_model)."
  echo "Project memories were preserved."
}

cmd_attach() {
  [ $# -ge 1 ] || die "Usage: orch attach <name>"
  local name="$1"
  require_worker "$name"
  local tmux_name="${TMUX_PREFIX}${name}"
  tmux_session_exists "$tmux_name" || die "tmux session '$tmux_name' not found. Worker may have exited."
  exec tmux attach -t "$tmux_name"
}

# =============================================================================
# Start / Stop orchestrator
# =============================================================================

cmd_start() {
  require_tmux
  require_claude

  local tmux_name="orch-main"

  if tmux_session_exists "$tmux_name"; then
    echo "Orchestrator already running in tmux session '$tmux_name'."
    echo "  Attach with: tmux attach -t $tmux_name"
    return
  fi

  tmux new-session -d -s "$tmux_name"

  # Launch claude with channels
  local launch_cmd="claude --channels plugin:discord@claude-plugins-official --dangerously-load-development-channels server:orchestrator-companion"
  tmux send-keys -t "$tmux_name" "$launch_cmd" Enter

  # Wait for the dev channels confirmation prompt, accept it
  sleep 3
  tmux send-keys -t "$tmux_name" Enter

  echo "Orchestrator starting in tmux session '$tmux_name'."
  echo "  Attach: tmux attach -t $tmux_name"
  echo "  Stop:   orch stop"
}

cmd_stop() {
  local tmux_name="orch-main"

  if ! tmux_session_exists "$tmux_name"; then
    echo "Orchestrator is not running."
    return
  fi

  tmux send-keys -t "$tmux_name" "/exit" Enter

  local waited=0
  while [ $waited -lt 5 ]; do
    sleep 1
    waited=$((waited + 1))
    tmux_session_exists "$tmux_name" || break
  done

  if tmux_session_exists "$tmux_name"; then
    tmux kill-session -t "$tmux_name" 2>/dev/null || true
    echo "Orchestrator force-stopped."
  else
    echo "Orchestrator stopped."
  fi
}

# =============================================================================
# Interactive Setup
# =============================================================================

cmd_setup() {
  echo ""
  echo "╔══════════════════════════════════════════════════════════╗"
  echo "║           ORCHESTRATOR SETUP                             ║"
  echo "╚══════════════════════════════════════════════════════════╝"
  echo ""

  # Step 1: Check prerequisites
  echo "STEP 1/7 — CHECKING PREREQUISITES"
  echo "──────────────────────────────────"
  local missing=false

  if command -v tmux &>/dev/null; then
    echo "  ✓ tmux $(tmux -V 2>/dev/null)"
  else
    echo "  ✗ tmux not found"
    echo "    Install: brew install tmux"
    missing=true
  fi

  if command -v claude &>/dev/null; then
    echo "  ✓ claude $(claude --version 2>/dev/null)"
  else
    echo "  ✗ claude CLI not found"
    echo "    Install: https://claude.ai/download"
    missing=true
  fi

  if command -v node &>/dev/null; then
    echo "  ✓ node $(node --version 2>/dev/null)"
  else
    echo "  ✗ node not found"
    echo "    Install: brew install node"
    missing=true
  fi

  if [ "$missing" = true ]; then
    echo ""
    echo "  Install missing prerequisites and re-run: orch setup"
    return 1
  fi
  echo ""

  # Step 2: Run install.sh
  echo "STEP 2/7 — INSTALLING ORCHESTRATOR"
  echo "───────────────────────────────────"
  local repo_dir
  repo_dir=$(cd "$(dirname "$(readlink -f "$(which orch)" 2>/dev/null || echo "$0")")" 2>/dev/null && cd .. && pwd)

  if [ -f "$repo_dir/install.sh" ]; then
    bash "$repo_dir/install.sh"
  elif [ -f "$ORCH_HOME/../install.sh" ]; then
    bash "$ORCH_HOME/../install.sh"
  else
    echo "  Orchestrator files already installed at $ORCH_HOME"
  fi
  echo ""

  # Step 3: Discord plugin
  echo "STEP 3/7 — DISCORD PLUGIN"
  echo "─────────────────────────"
  if [ -d "$HOME/.claude/plugins/marketplaces/claude-plugins-official/external_plugins/discord" ]; then
    echo "  ✓ Discord plugin already installed"
  else
    echo "  The Discord plugin connects Claude Code to your Discord server."
    echo ""
    echo "  Run this in a Claude Code session:"
    echo "    /plugin install discord@claude-plugins-official"
    echo "    /reload-plugins"
    echo ""
    echo -n "  Press Enter once you've installed the plugin (or 's' to skip): "
    read -r response
    if [ "$response" = "s" ]; then
      echo "  Skipped."
    fi
  fi
  echo ""

  # Step 4: Discord bot token
  echo "STEP 4/7 — DISCORD BOT SETUP"
  echo "────────────────────────────"
  if [ -f "$HOME/.claude/channels/discord/.env" ] && grep -q "DISCORD_BOT_TOKEN" "$HOME/.claude/channels/discord/.env" 2>/dev/null; then
    echo "  ✓ Bot token already configured"
  else
    echo "  Create a Discord bot:"
    echo "  1. Go to: https://discord.com/developers/applications"
    echo "  2. Click 'New Application' → name it 'Claude Orchestrator'"
    echo "  3. Go to 'Bot' tab → click 'Reset Token' → copy the token"
    echo "  4. Enable 'Message Content Intent' under Privileged Gateway Intents"
    echo "  5. Go to 'OAuth2 → URL Generator'"
    echo "     - Scopes: bot"
    echo "     - Permissions: View Channels, Send Messages, Send/Create/Manage Threads,"
    echo "       Manage Channels, Read History, Attach Files, Add Reactions, Embed Links"
    echo "  6. Copy the generated URL and open it to invite the bot to your server"
    echo ""
    echo -n "  Paste your bot token (or 's' to skip): "
    read -r token
    if [ "$token" != "s" ] && [ -n "$token" ]; then
      mkdir -p "$HOME/.claude/channels/discord"
      echo "DISCORD_BOT_TOKEN=$token" > "$HOME/.claude/channels/discord/.env"
      chmod 600 "$HOME/.claude/channels/discord/.env"
      echo "  ✓ Token saved"

      # Configure via claude skill
      echo ""
      echo "  Now configure the plugin in a Claude Code session:"
      echo "    /discord:configure $token"
      echo ""
      echo -n "  Press Enter once done (or 's' to skip): "
      read -r response
    else
      echo "  Skipped."
    fi
  fi
  echo ""

  # Step 5: Discord server setup
  echo "STEP 5/7 — DISCORD SERVER CHANNELS"
  echo "───────────────────────────────────"
  if [ -f "$ORCH_HOME/config.json" ] && command -v jq &>/dev/null; then
    local main_id
    main_id=$(jq -r '.discord.main_channel_id // empty' "$ORCH_HOME/config.json" 2>/dev/null)
    if [ -n "$main_id" ]; then
      echo "  ✓ Discord channels already configured"
      echo "    main: $main_id"
      echo "    notifications: $(jq -r '.discord.notifications_channel_id // "?"' "$ORCH_HOME/config.json")"
      echo "    tasks: $(jq -r '.discord.tasks_channel_id // "?"' "$ORCH_HOME/config.json")"
    else
      echo "  Need to create #main, #notifications, #tasks channels."
      echo ""
      echo -n "  Enter your Discord server (guild) ID (right-click server → Copy Server ID): "
      read -r guild_id
      if [ -n "$guild_id" ] && [ "$guild_id" != "s" ]; then
        echo "  Running setup script to create channels..."
        if [ -f "$ORCH_HOME/channel/src/setup.ts" ]; then
          local bot_token
          bot_token=$(grep "DISCORD_BOT_TOKEN" "$HOME/.claude/channels/discord/.env" 2>/dev/null | cut -d= -f2)
          if [ -n "$bot_token" ]; then
            (cd "$ORCH_HOME/channel" && DISCORD_BOT_TOKEN="$bot_token" GUILD_ID="$guild_id" npx tsx src/setup.ts 2>&1)
          else
            echo "  ✗ No bot token found. Configure it first."
          fi
        else
          echo "  ✗ Setup script not found. Run install.sh first."
        fi
      else
        echo "  Skipped."
      fi
    fi
  else
    echo "  Run install.sh first to create config.json."
  fi
  echo ""

  # Step 6: Pair Discord account
  echo "STEP 6/7 — PAIR YOUR DISCORD ACCOUNT"
  echo "─────────────────────────────────────"
  if [ -f "$HOME/.claude/channels/discord/access.json" ] && command -v python3 &>/dev/null; then
    local sender_count
    sender_count=$(python3 -c "import json; d=json.load(open('$HOME/.claude/channels/discord/access.json')); print(len(d.get('allowFrom',[])))" 2>/dev/null || echo "0")
    if [ "$sender_count" -gt 0 ]; then
      echo "  ✓ $sender_count account(s) paired and allowlisted"
    else
      echo "  No accounts paired yet."
      echo ""
      echo "  In a Claude Code session with the Discord plugin loaded:"
      echo "  1. Start Claude with: claude --channels plugin:discord@claude-plugins-official"
      echo "  2. DM your bot on Discord — it will reply with a pairing code"
      echo "  3. Run: /discord:access pair <code>"
      echo "  4. Lock down: /discord:access policy allowlist"
      echo ""
      echo -n "  Press Enter once done (or 's' to skip): "
      read -r response
    fi
  else
    echo "  Complete steps 3-5 first."
  fi
  echo ""

  # Step 7: Register companion server
  echo "STEP 7/7 — COMPANION MCP SERVER"
  echo "───────────────────────────────"
  if claude mcp list 2>/dev/null | grep -q "orchestrator-companion"; then
    echo "  ✓ Companion server already registered"
  else
    echo "  Registering the companion MCP server..."
    local bot_token guild_id notif_id tasks_id
    bot_token=$(grep "DISCORD_BOT_TOKEN" "$HOME/.claude/channels/discord/.env" 2>/dev/null | cut -d= -f2)
    if [ -n "$bot_token" ] && command -v jq &>/dev/null && [ -f "$ORCH_HOME/config.json" ]; then
      guild_id=$(jq -r '.discord.guild_id // empty' "$ORCH_HOME/config.json")
      notif_id=$(jq -r '.discord.notifications_channel_id // empty' "$ORCH_HOME/config.json")
      tasks_id=$(jq -r '.discord.tasks_channel_id // empty' "$ORCH_HOME/config.json")

      if [ -n "$guild_id" ] && [ -n "$notif_id" ]; then
        claude mcp add-json -s user orchestrator-companion "{
          \"command\": \"npx\",
          \"args\": [\"--prefix\", \"$ORCH_HOME/channel\", \"tsx\", \"$ORCH_HOME/channel/src/server.ts\"],
          \"env\": {
            \"DISCORD_BOT_TOKEN\": \"$bot_token\",
            \"GUILD_ID\": \"$guild_id\",
            \"NOTIFICATIONS_CHANNEL_ID\": \"$notif_id\",
            \"TASKS_CHANNEL_ID\": \"$tasks_id\",
            \"ORCH_PORT\": \"9111\",
            \"ORCH_HOME\": \"$ORCH_HOME\"
          }
        }" 2>/dev/null
        echo "  ✓ Companion server registered"
      else
        echo "  ✗ Missing Discord channel IDs. Complete step 5 first."
      fi
    else
      echo "  ✗ Missing bot token or config. Complete steps 4-5 first."
    fi
  fi
  echo ""

  # Summary
  echo "╔══════════════════════════════════════════════════════════╗"
  echo "║           SETUP COMPLETE                                 ║"
  echo "╚══════════════════════════════════════════════════════════╝"
  echo ""
  echo "  Start the orchestrator:"
  echo "    orch start"
  echo ""
  echo "  Open the dashboard:"
  echo "    http://localhost:9111"
  echo ""
  echo "  Message your bot on Discord to control workers."
  echo ""
}

# =============================================================================
# Main dispatch
# =============================================================================

case "${1:-help}" in
  spawn)   shift; cmd_spawn "$@" ;;
  send)    shift; cmd_send "$@" ;;
  status)  shift; cmd_status "$@" ;;
  list)    shift; cmd_list "$@" ;;
  logs)    shift; cmd_logs "$@" ;;
  kill)    shift; cmd_kill "$@" ;;
  cleanup) shift; cmd_cleanup "$@" ;;
  attach)  shift; cmd_attach "$@" ;;
  remodel) shift; cmd_remodel "$@" ;;
  start)   shift; cmd_start "$@" ;;
  stop)    shift; cmd_stop "$@" ;;
  setup)   shift; cmd_setup "$@" ;;
  spawn-deferred) shift; cmd_spawn_deferred "$@" ;;
  project) shift; cmd_project "$@" ;;
  memory)  shift; cmd_memory "$@" ;;
  help|-h|--help) cmd_help ;;
  *)       die "Unknown command: $1. Run 'orch help' for usage." ;;
esac
